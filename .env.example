SEOUL_API_KEY=
SEOUL_METRO_KEY=

# Fill these when the SK Open API spec is finalized in the app.
# The URL is intentionally template-based so placeholders can be mapped
# without another code change.
# Supported placeholders:
# {station_name} {station_name_norm} {api_station_name}
# {station_id} {subway_id} {line} {direction}
# {date} {datetime}
SK_APP_KEY=
SK_SUBWAY_CONGESTION_URL=
SK_REALTIME_CONGESTION_MONTHLY_LIMIT=10
SK_REALTIME_CONGESTION_TIMEOUT=10
